# Vite Environment Variables for PulseQ Frontend

# API Configuration
# The base URL for the backend API (client-side requests)
# Default: http://localhost:8000
VITE_API_URL=https://api.pulseq.health

# SSR Configuration (for Server-Side Rendering)
# The base URL for the SSR backend (server-side requests during build)
# Default: http://localhost:4000
VITE_SSR_URL=http://localhost:4000

# Environment mode
# Options: development, production, staging
VITE_ENV_MODE=development

# Optional: Can also be set via NODE_ENV or process.env.SSR_BASE_URL at runtime
# NODE_ENV=development
