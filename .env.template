# Application Settings
ENVIRONMENT=production
PORT=10000
DEBUG=False
PROJECT_NAME=PulseQ Backend

# ⚠️ SECURITY: Generate a strong SECRET_KEY for production
# Run this command to generate: python -c "import secrets; print(secrets.token_hex(32))"
# Set a unique, strong secret in your actual .env file (never commit real secrets!)
SECRET_KEY=your-secret-key-change-in-production

# Database Configuration
DB_HOST=your-database-host
DB_NAME=your-database-name
DB_USER=your-database-user
DB_PASSWORD=your-database-password
DB_PORT=5432

# CORS Settings
WEB_BASE_URL=https://pulseq.health
MOBILE_BASE_URL=https://patient.pulseq.health
ALLOWED_ORIGINS=https://pulseq.health,https://www.pulseq.health,https://patient.pulseq.health,https://doctor.pulseq.health,https://reception.pulseq.health,https://pharmacy.pulseq.health,https://admin.pulseq.health,https://demo.pulseq.health

# ⚠️ JWT Settings (REQUIRED - at least one must be set)
# The app will use SECRET_KEY first, then fall back to JWT_SECRET_KEY
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours

# AI Model Paths (relative to project root)
MODEL_PATH=models/opd_wait_time_model.pkl
ENCODER_PATH=models/label_encoders.pkl

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json  

# Rate Limiting (requests per minute)
RATE_LIMIT=100