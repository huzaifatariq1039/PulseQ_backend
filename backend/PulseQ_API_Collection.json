              "path": ["api", "v1", "doctor", "queue", "token", "{{token_id}}", "skip"]
            },
            "description": "Skip a token in queue"
          },
          "response": []
        },
        {
          "name": "Complete Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/doctor/queue/token/{{token_id}}/complete",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "doctor", "queue", "token", "{{token_id}}", "complete"]
            },
            "description": "Complete consultation for a token"
          },
          "response": []
        }
      ]
