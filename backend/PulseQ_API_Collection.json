            "url": {
              "raw": "{{base_url}}/api/v1/patient/dashboard",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "patient", "dashboard"]
            },
            "description": "Get patient dashboard data"
          },
          "response": []
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/patient/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "patient", "profile"]
            },
            "description": "Get patient profile"
          },
          "response": []
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"address\": \"New Address\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/patient/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "patient", "profile"]
            },
            "description": "Update patient profile"
          },
          "response": []
        },
        {
          "name": "Generate Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctor_id\": \"doc_123\",\n  \"hospital_id\": \"hosp_456\",\n  \"appointment_date\": \"2026-04-07T10:00:00\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/patient/tokens/generate",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "patient", "tokens", "generate"]
            },
            "description": "Generate a new token for appointment"
          },
          "response": []
        },
        {
          "name": "Get My Tokens",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/patient/tokens/my-tokens",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "patient", "tokens", "my-tokens"]
            },
            "description": "Get all tokens for current patient"
          },
          "response": []
        },
        {
          "name": "Cancel Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"schedule_conflict\",\n  \"refund_method\": \"original_payment\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/patient/tokens/{{token_id}}/cancel",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "patient", "tokens", "{{token_id}}", "cancel"]
            },
            "description": "Cancel a token/appointment"
          },
          "response": []
        },
        {
          "name": "Get Queue Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/patient/queue/doctor/{{doctor_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "patient", "queue", "doctor", "{{doctor_id}}"]
            },
            "description": "Get queue status for a doctor"
          },
          "response": []
        },
        {
          "name": "Process Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token_id\": \"token_123\",\n  \"amount\": 500,\n  \"method\": \"online\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/patient/payments/process",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "patient", "payments", "process"]
            },
            "description": "Process payment for a token"
          },
          "response": []
        }
      ]
