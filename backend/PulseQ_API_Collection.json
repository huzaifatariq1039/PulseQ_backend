    {
      "name": "Authentication",
      "item": [
        {
          "name": "Check Phone Exists",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/check-phone/+923001234567",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "check-phone", "+923001234567"]
            },
            "description": "Check if a phone number is already registered"
          },
          "response": []
        },
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"phone\": \"+923001234567\",\n  \"password\": \"testpassword123\",\n  \"role\": \"patient\",\n  \"auth_method\": \"phone\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Register a new user (patient, doctor, admin, etc.)"
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"+923001234567\",\n  \"password\": \"testpassword123\",\n  \"auth_method\": \"phone\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Login with phone/email and password. Returns access_token."
          },
          "response": []
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "me"]
            },
            "description": "Get current logged-in user details"
          },
          "response": []
        },
        {
          "name": "Pharmacy Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"pharmacy@example.com\",\n  \"password\": \"pharmacypassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/pharmacy/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "pharmacy", "login"]
            },
            "description": "Login specifically for pharmacy users"
          },
          "response": []
        }
      ]
