PORT=5055

# Firebase Admin
# Preferred: embed the entire service account JSON.
FIREBASE_SERVICE_ACCOUNT_JSON=

# WhatsApp Cloud API (Meta)
# Get a real token from Meta Business Platform and set it in your .env file
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token-change-in-production
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id

# Template configuration (optional)
WHATSAPP_TEMPLATE_NAME=token_number
WHATSAPP_TEMPLATE_LANGUAGE=en

# Cron
CRON_EXPRESSION=* * * * *
CRON_BATCH_LIMIT=50

